{
  "manifest_version": 3,
  "name": "MMCP Connect",
  "description": "Connexion MMCP, suivi des sorties et notifications.",
  "version": "1.0.0",
  "action": {
    "default_title": "MMCP Connect",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon-128.png"
    }
  },
  "icons": {
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ]
}