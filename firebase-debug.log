[debug] [2026-05-24T13:29:56.963Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/morgann-music-cp/rulesets {"name":"projects/morgann-music-cp/rulesets/6b662473-0feb-4e8f-86bd-96bb32a41c5b","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /users/{userId} {\n      allow create: if request.auth != null && request.auth.uid == userId;\n      allow read, delete: if request.auth != null && request.auth.uid == userId;\n\n      // L'utilisateur peut modifier son document, mais pas le nom d'artiste.\n      allow update: if request.auth != null\n        && request.auth.uid == userId\n        && request.resource.data.artistName == resource.data.artistName;\n    }\n\n    // Demandes de changement de nom d'artiste\n    match /artistNameChangeRequests/{requestId} {\n      allow create: if request.auth != null\n        && request.resource.data.userId == request.auth.uid\n        && request.resource.data.newArtistName is string\n        && request.resource.data.newArtistName.size() > 0\n        && request.resource.data.consent15Days == true;\n\n      allow read: if request.auth != null && resource.data.userId == request.auth.uid;\n      allow update, delete: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-24T13:29:56.988383Z","metadata":{"services":["cloud.firestore"]}}
